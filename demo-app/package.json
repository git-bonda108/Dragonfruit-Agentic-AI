{
  "name": "dragonfruit-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "echo '' && echo '>>> OPEN IN BROWSER: http://localhost:3000 <<<' && echo '' && vite",
    "start": "node server.js",
    "run": "vite",
    "kill3000": "lsof -ti :3000 | xargs kill -9 2>/dev/null || true",
    "backend": "cd backend && uvicorn main:app --reload --port 8000",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "~5.6.2",
    "vite": "^5.4.10"
  }
}
